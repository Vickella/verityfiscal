# VERITYFiscal Environment Configuration

# FDMS API Configuration
FDMS_API_KEY=your_fdms_api_key_here
FDMS_API_SECRET=your_fdms_api_secret_here
FDMS_ENVIRONMENT=sandbox

# ERPNext Configuration
FRAPPE_DB_NAME=frappe_prod
FRAPPE_DB_USER=frappe
FRAPPE_DB_PASSWORD=your_db_password

# App Configuration
ENCRYPTION_KEY=your_encryption_key_here
SECRET_KEY=your_secret_key_here

# Logging
LOG_LEVEL=INFO

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Retry Configuration
RETRY_ATTEMPTS=3
RETRY_INTERVAL=300

# Feature Flags
AUTO_FISCALISE_INVOICES=false
AUTO_SYNC_DEVICES=true
GENERATE_COMPLIANCE_REPORTS=true
RETRY_FAILED_TRANSMISSIONS=true
